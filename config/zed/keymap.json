[
  {
    "unbind": {
      "ctrl-q": "zed::Quit"
    },
    "bindings": {
      // Toggles via Hyper key (super+ctrl+alt+shift)
      "super-ctrl-alt-shift-enter": "agent::ToggleFocus", // use enter, space+a is used for code actions
      "super-ctrl-alt-shift-d": "debug_panel::ToggleFocus",
      "super-ctrl-alt-shift-e": "project_panel::ToggleFocus",
      "super-ctrl-alt-shift-g": "git_panel::ToggleFocus",
      "super-ctrl-alt-shift-o": "outline_panel::ToggleFocus",
      "super-ctrl-alt-shift-t": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-d": "debug_panel::ToggleFocus"
    },
    "bindings": {
      "ctrl-~": "workspace::NewCenterTerminal", // default: workspace::NewTerminal

      // Toggles via Meh key (ctrl+alt+shift)
      "ctrl-alt-(": "workspace::ToggleLeftDock",
      "ctrl-alt-)": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "!Terminal",
    "unbind": {
      // Disable because I keep hitting this key combo accidentally.
      "ctrl-shift-c": "collab_panel::ToggleFocus"
    }
  },
  {
    // Needed for which_key popup to stay open.
    "context": "VimControl && !menu",
    "unbind": {
      "space": "vim::WrappingRight"
    }
  }
]
