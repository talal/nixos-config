[
  {
    "label": "Typst: watch file with worktree set as root",
    "command": "typst",
    "args": [
      "watch",
      "--creation-timestamp=$(date +%s)",
      "--root=\"$ZED_WORKTREE_ROOT\"",
      "\"$ZED_RELATIVE_FILE\""
    ],
    "use_new_terminal": true,
    "reveal": "no_focus",
    "hide": "always"
  }
]
