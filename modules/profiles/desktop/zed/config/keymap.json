[
  {
    "unbind": {
      "ctrl-q": "zed::Quit",
      "ctrl-shift-w": "workspace::CloseWindow"
    },
    "bindings": {
      // Toggles via Meh key (ctrl+alt+shift)
      "ctrl-alt-shift-h": "workspace::ToggleLeftDock",
      "ctrl-alt-shift-j": "workspace::ToggleBottomDock",
      "ctrl-alt-shift-k": "editor::ToggleTabBar",
      "ctrl-alt-shift-l": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-~": "workspace::NewCenterTerminal", // default: workspace::NewTerminal
    }
  },
  {
    "context": "!Terminal",
    "unbind": {
      // Disable because I keep hitting this key combo accidentally.
      "ctrl-shift-c": "collab_panel::ToggleFocus"
    }
  },
  {
    // Needed for which_key popup to stay open.
    "context": "VimControl && !menu",
    "unbind": {
      "space": "vim::WrappingRight"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "ctrl-s": "editor::SaveLocation",
      "space b": "tab_switcher::ToggleAll"
    },
    "bindings": {
      "ctrl-alt-s": "editor::SaveLocation",

      // Line Selection (Aligns with Helix x/X)
      "shift-x": "editor::SelectUp",

      // Splits/Pane Navigation (Aligns with Helix C-h/j/k/l)
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",

      // AST Parent Node Navigation (Aligns with Helix tab/S-tab)
      "tab": "editor::SelectLargerSyntaxNode",
      "shift-tab": "editor::SelectSmallerSyntaxNode",

      // space.b minor mode for buffer tasks
      "space b b": "tab_switcher::ToggleAll",
      "space b q": "pane::CloseActiveItem",
      "space b o": "pane::CloseOtherItems",

      // space.l minor mode for code tasks
      "space l f": "editor::Format",
      "space l q": "editor::Rewrap",
      "space l s": "editor::SortLinesCaseInsensitive",
      "space l i": "editor::ToggleInlayHints",
      "space l z": "editor::ToggleSoftWrap"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "shift-tab": "editor::SelectSmallerSyntaxNode"
    }
  }
]
