{
  // ══════════ General ══════════
  "disable_ai": true,
  "cli_default_open_behavior": "new_window",
  "restore_on_startup": "launchpad",
  "load_direnv": "shell_hook",
  "telemetry": { "diagnostics": false, "metrics": false },
  "auto_install_extensions": {
    "catppuccin": true
  },

  // ══════════ Profiles ══════════
  "profiles": {
    "Presentation": {
      "settings": {
        "disable_ai": true,
        "theme": "One Light",
        "helix_mode": false,
        "relative_line_numbers": "disabled",
        "which_key": { "enabled": false }
      }
    }
  },

  // ══════════ AI ══════════
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "tool_permissions": { "default": "allow" },
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "effort": "medium",
      "enable_thinking": true
    },
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6"
    }
  },
  "edit_predictions": { "provider": "zed", "mode": "subtle" },

  // ══════════ Appearance ══════════
  "theme": "Catppuccin Macchiato",
  "buffer_font_family": "TX02 Nerd Font",
  "buffer_font_size": 18,
  "ui_font_size": 19,
  "agent_buffer_font_size": 17,
  "agent_ui_font_size": 20,

  // ══════════ Terminal ══════════
  "terminal": {
    "dock": "right",
    "blinking": "on",
    "cursor_shape": "bar",
    "shell": { "program": "fish" },
    "env": {
      "EDITOR": "zeditor --wait",
      "VISUAL": "zeditor --wait"
    }
  },

  // ══════════ Editor ══════════
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "diff_view_style": "unified",
  "go_to_definition_fallback": "none", // disable weird ctrl-click behavior
  "preferred_line_length": 90,
  "wrap_guides": [80, 100],
  "inlay_hints": {
    "toggle_on_modifiers_press": { "control": true, "alt": true }
  },

  // ══════════ Helix ══════════
  "helix_mode": true,
  "relative_line_numbers": "enabled",
  "which_key": { "enabled": true, "delay_ms": 0 },

  // ══════════ Languages ══════════
  "file_types": {
    "YAML": ["base", ".clang-format", ".clang-tidy"]
  },
  "languages": {
    "Fish": {
      "formatter": { "external": { "command": "fish_indent" } }
    },
    "HTML": {
      "language_servers": ["superhtml", "..."],
      "formatter": { "language_server": { "name": "superhtml" } }
    },
    "Markdown": {
      "formatter": {
        "external": { "command": "mdformat", "arguments": ["--number", "-"] }
      }
    },
    "Nix": {
      "language_servers": ["nixd"],
      "formatter": {
        "external": { "command": "alejandra", "arguments": ["--quiet", "--"] }
      }
    },
    "Python": {
      "language_servers": ["ty", "ruff"],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true // Fix all auto-fixable lint violations
      }
    },
    "Shell Script": {
      "formatter": {
        "external": { "command": "shfmt", "arguments": ["--simplify"] }
      }
    },
    "TOML": {
      "formatter": {
        "external": {
          "command": "taplo",
          "arguments": [
            "format",
            "--option=align_comments=false",
            "--option=column_width=100",
            "--option=inline_table_expand=false",
            "-"
          ]
        }
      }
    },
    "Typst": {
      "allow_rewrap": "anywhere",
      "soft_wrap": "editor_width",
      "formatter": {
        "external": { "command": "typstyle", "arguments": ["--line-width=100"] }
      }
    }
  }
}
